// Update embed preview
function updateEmbedPreview() {
    const preview = document.getElementById('embed-preview');
    const markdownOutput = document.getElementById('embed-markdown-output');
    if (!preview || !markdownOutput) return;
    
    // Get all form values
    const title = document.getElementById('embed-title')?.value || '';
    const description = document.getElementById('embed-description')?.value || '';
    const color = document.getElementById('embed-color-text')?.value || '#338ac4';
    const authorName = document.getElementById('embed-author-name')?.value || '';
    const authorIcon = document.getElementById('embed-author-icon')?.value || '';
    const footerText = document.getElementById('embed-footer-text')?.value || '';
    const footerIcon = document.getElementById('embed-footer-icon')?.value || '';
    const thumbnail = document.getElementById('embed-thumbnail')?.value || '';
    const image = document.getElementById('embed-image')?.value || '';
    const timestamp = document.getElementById('embed-timestamp')?.checked || false;
    
    // Get fields
    const fields = [];
    document.querySelectorAll('.embed-field-item').forEach(fieldDiv => {
        const name = fieldDiv.querySelector('.embed-field-name')?.value || '';
        const value = fieldDiv.querySelector('.embed-field-value')?.value || '';
        const inline = fieldDiv.querySelector('.embed-field-inline')?.checked || false;
        if (name || value) {
            fields.push({ name, value, inline });
        }
    });
    
    // Build embed markdown
    let markdown = '```json\n{\n';
    markdown += '  "embeds": [{\n';
    
    if (title) markdown += `    "title": ${JSON.stringify(title)},\n`;
    if (description) markdown += `    "description": ${JSON.stringify(description)},\n`;
    if (color) markdown += `    "color": ${parseInt(color.replace('#', ''), 16)},\n`;
    
    if (authorName || authorIcon) {
        markdown += '    "author": {\n';
        if (authorName) markdown += `      "name": ${JSON.stringify(authorName)},\n`;
        if (authorIcon) markdown += `      "icon_url": ${JSON.stringify(authorIcon)},\n`;
        markdown = markdown.replace(/,\n$/, '\n');
        markdown += '    },\n';
    }
    
    if (fields.length > 0) {
        markdown += '    "fields": [\n';
        fields.forEach((field, index) => {
            markdown += '      {\n';
            markdown += `        "name": ${JSON.stringify(field.name)},\n`;
            markdown += `        "value": ${JSON.stringify(field.value)},\n`;
            markdown += `        "inline": ${field.inline}\n`;
            markdown += '      }';
            if (index < fields.length - 1) markdown += ',';
            markdown += '\n';
        });
        markdown += '    ],\n';
    }
    
    if (thumbnail) markdown += `    "thumbnail": { "url": ${JSON.stringify(thumbnail)} },\n`;
    if (image) markdown += `    "image": { "url": ${JSON.stringify(image)} },\n`;
    
    if (footerText || footerIcon) {
        markdown += '    "footer": {\n';
        if (footerText) markdown += `      "text": ${JSON.stringify(footerText)},\n`;
        if (footerIcon) markdown += `      "icon_url": ${JSON.stringify(footerIcon)},\n`;
        markdown = markdown.replace(/,\n$/, '\n');
        markdown += '    },\n';
    }
    
    if (timestamp) markdown += '    "timestamp": "' + new Date().toISOString() + '",\n';
    
    markdown = markdown.replace(/,\n$/, '\n');
    markdown += '  }]\n';
    markdown += '}\n```';
    
    markdownOutput.value = markdown;
    
    // Update visual preview
    let previewHTML = '';
    if (title) previewHTML += `<div style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">${escapeHtml(title)}</div>`;
    if (description) previewHTML += `<div style="margin-bottom: 1rem; color: var(--text-secondary); white-space: pre-wrap;">${escapeHtml(description)}</div>`;
    
    if (fields.length > 0) {
        previewHTML += '<div style="margin-top: 1rem;">';
        fields.forEach(function(field) {
            var inlineStyle = field.inline ? 'display: inline-block; width: 48%; margin-right: 2%;' : '';
            var fieldDiv = '<div style="margin-bottom: 0.75rem; ' + inlineStyle + '">';
            fieldDiv += '<div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">' + escapeHtml(field.name) + '</div>';
            fieldDiv += '<div style="color: var(--text-secondary); white-space: pre-wrap;">' + escapeHtml(field.value) + '</div>';
            fieldDiv += '</div>';
            previewHTML += fieldDiv;
        });
        previewHTML += '</div>';
    }
    
    if (footerText) {
        previewHTML += `<div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.875rem; color: var(--text-secondary);">${escapeHtml(footerText)}</div>`;
    }
    
    preview.style.borderLeftColor = color;
    preview.innerHTML = previewHTML || '<p style="color: var(--text-secondary); text-align: center; padding: 2rem;">Preview will appear here</p>';
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Add change listeners to all embed form fields
const embedFormFields = [
    'embed-title', 'embed-description', 'embed-author-name', 'embed-author-icon',
    'embed-footer-text', 'embed-footer-icon', 'embed-thumbnail', 'embed-image', 'embed-timestamp'
];

embedFormFields.forEach(fieldId => {
    const field = document.getElementById(fieldId);
    if (field) {
        field.addEventListener('input', updateEmbedPreview);
        if (field.type === 'checkbox') {
            field.addEventListener('change', updateEmbedPreview);
        }
    }
});

// Modal open/close handlers
if (embedEditorBtn && embedEditorModal) {
    embedEditorBtn.addEventListener('click', () => {
        // Parse existing markdown if present
        if (dmMessageTextarea && dmMessageTextarea.value.trim()) {
            parseEmbedMarkdown(dmMessageTextarea.value);
        } else {
            // Reset form to defaults
            const titleEl = document.getElementById('embed-title');
            const descEl = document.getElementById('embed-description');
            const colorTextEl = document.getElementById('embed-color-text');
            const colorPickerEl = document.getElementById('embed-color-picker');
            const fieldsListEl = document.getElementById('embed-fields-list');
            
            if (titleEl) titleEl.value = '';
            if (descEl) descEl.value = '';
            if (colorTextEl) colorTextEl.value = '#338ac4';
            if (colorPickerEl) colorPickerEl.value = '#338ac4';
            if (fieldsListEl) {
                fieldsListEl.innerHTML = '';
                embedFieldCounter = 0;
            }
        }
        embedEditorModal.style.display = 'flex';
        // Small delay to ensure DOM is ready
        setTimeout(updateEmbedPreview, 100);
    });
}

if (embedEditorClose) {
    embedEditorClose.addEventListener('click', () => {
        embedEditorModal.style.display = 'none';
    });
}

if (embedEditorCancel) {
    embedEditorCancel.addEventListener('click', () => {
        embedEditorModal.style.display = 'none';
    });
}

if (embedEditorSave) {
    embedEditorSave.addEventListener('click', () => {
        const markdownOutput = document.getElementById('embed-markdown-output');
        if (markdownOutput && dmMessageTextarea) {
            dmMessageTextarea.value = markdownOutput.value;
        }
        embedEditorModal.style.display = 'none';
    });
}

// Close modal when clicking outside
if (embedEditorModal) {
    embedEditorModal.addEventListener('click', (e) => {
        if (e.target === embedEditorModal) {
            embedEditorModal.style.display = 'none';
        }
    });
}

// Parse existing embed markdown
function parseEmbedMarkdown(markdown) {
    try {
        if (!markdown || typeof markdown !== 'string') return;
        
        // Extract JSON from markdown code block
        const jsonMatch = markdown.match(/```json\s*([\s\S]*?)\s*```/);
        if (!jsonMatch) return;
        
        const jsonStr = jsonMatch[1];
        const data = JSON.parse(jsonStr);
        
        if (data.embeds && data.embeds[0]) {
            const embed = data.embeds[0];
            
            const titleEl = document.getElementById('embed-title');
            const descEl = document.getElementById('embed-description');
            const colorTextEl = document.getElementById('embed-color-text');
            const colorPickerEl = document.getElementById('embed-color-picker');
            const authorNameEl = document.getElementById('embed-author-name');
            const authorIconEl = document.getElementById('embed-author-icon');
            const footerTextEl = document.getElementById('embed-footer-text');
            const footerIconEl = document.getElementById('embed-footer-icon');
            const thumbnailEl = document.getElementById('embed-thumbnail');
            const imageEl = document.getElementById('embed-image');
            const timestampEl = document.getElementById('embed-timestamp');
            const fieldsListEl = document.getElementById('embed-fields-list');
            
            if (titleEl && embed.title) titleEl.value = embed.title;
            if (descEl && embed.description) descEl.value = embed.description;
            
            if (colorTextEl && colorPickerEl && embed.color !== undefined) {
                let colorHex;
                if (typeof embed.color === 'number') {
                    colorHex = '#' + embed.color.toString(16).padStart(6, '0');
                } else if (typeof embed.color === 'string') {
                    colorHex = embed.color.startsWith('#') ? embed.color : '#' + embed.color;
                } else {
                    colorHex = '#338ac4';
                }
                colorTextEl.value = colorHex;
                colorPickerEl.value = colorHex;
            }
            
            if (embed.author) {
                if (authorNameEl && embed.author.name) authorNameEl.value = embed.author.name;
                if (authorIconEl && embed.author.icon_url) authorIconEl.value = embed.author.icon_url;
            }
            
            if (embed.footer) {
                if (footerTextEl && embed.footer.text) footerTextEl.value = embed.footer.text;
                if (footerIconEl && embed.footer.icon_url) footerIconEl.value = embed.footer.icon_url;
            }
            
            if (thumbnailEl && embed.thumbnail && embed.thumbnail.url) thumbnailEl.value = embed.thumbnail.url;
            if (imageEl && embed.image && embed.image.url) imageEl.value = embed.image.url;
            if (timestampEl) timestampEl.checked = !!embed.timestamp;
            
            // Clear existing fields
            if (fieldsListEl) {
                fieldsListEl.innerHTML = '';
                embedFieldCounter = 0;
                
                // Add fields
                if (embed.fields && Array.isArray(embed.fields)) {
                    embed.fields.forEach(field => {
                        addEmbedField(field.name || '', field.value || '', field.inline || false);
                    });
                }
            }
        }
    } catch (error) {
        console.error('Error parsing embed markdown:', error);
    }
}

