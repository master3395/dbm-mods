// Load channels and roles when create pane is shown
// Use var for hoisting to prevent initialization errors
var SERVER_ID = null;
<% if (data.server && data.server.id) { %>
SERVER_ID = '<%= data.server.id %>';
<% } %>

// basePath is already defined in scripts-core-part1.ejs as const
// We just need to ensure we have a reference to it
// Don't redeclare it - just use the existing one or fallback
var getBasePath = function() {
    if (typeof basePath !== 'undefined') {
        return basePath;
    }
    return window.location.pathname.startsWith('/nt2') ? '/nt2' : '';
};

var rolesLoaded = false;
var serverRoles = [];
var createPane = null;
var createTab = null;

// Initialize DOM elements
function initDOMElements() {
    if (!createPane) {
        createPane = document.getElementById('giveaways-create');
    }
    if (!createTab) {
        createTab = document.querySelector('[data-panel-target="giveaways-create"]');
    }
    return createPane && createTab;
}

// Function to load channels from API (similar to loadServerRoles)
async function loadServerChannels() {
    if (!SERVER_ID) {
        console.warn('[loadServerChannels] Server ID not available for loading channels');
        return [];
    }
    try {
        const basePathValue = getBasePath();
        const url = basePathValue + '/api/servers/' + SERVER_ID + '/channels';
        console.log('[loadServerChannels] Fetching channels from:', url);
        console.log('[loadServerChannels] SERVER_ID:', SERVER_ID);
        
        // Disable cache for this request
        const response = await fetch(url, {
            cache: 'no-store',
            headers: {
                'Cache-Control': 'no-cache',
                'Pragma': 'no-cache'
            }
        });
        console.log('[loadServerChannels] Response status:', response.status, response.statusText);
        console.log('[loadServerChannels] Response headers:', Object.fromEntries(response.headers.entries()));
        
        // Handle 304 Not Modified - force a fresh request
        let result;
        let actualResponse = response;
        
        if (response.status === 304) {
            console.warn('[loadServerChannels] Received 304 Not Modified, forcing fresh request...');
            actualResponse = await fetch(url + '?t=' + Date.now(), {
                cache: 'no-store',
                headers: {
                    'Cache-Control': 'no-cache',
                    'Pragma': 'no-cache'
                }
            });
            console.log('[loadServerChannels] Fresh response status:', actualResponse.status);
        }
        
        try {
            const responseText = await actualResponse.text();
            console.log('[loadServerChannels] Raw response:', responseText);
            result = JSON.parse(responseText);
        } catch (parseError) {
            console.error('[loadServerChannels] Failed to parse JSON response:', parseError);
            throw new Error('Invalid JSON response from server: ' + parseError.message);
        }
        
        console.log('[loadServerChannels] Parsed result:', result);
        
        if (!actualResponse.ok) {
            throw new Error('API error: ' + (result.error || actualResponse.statusText) + ' (Status: ' + actualResponse.status + ')');
        }
        
        if (result.success && Array.isArray(result.data)) {
            console.log(`[loadServerChannels] Successfully loaded ${result.data.length} channels`);
            console.log('[loadServerChannels] Channel data:', result.data);
            return result.data;
        } else {
            console.warn('[loadServerChannels] Channels API returned unsuccessful response:', result);
            console.warn('[loadServerChannels] result.success:', result.success);
            console.warn('[loadServerChannels] result.data type:', typeof result.data);
            console.warn('[loadServerChannels] result.data is array:', Array.isArray(result.data));
            if (result.data) {
                console.warn('[loadServerChannels] result.data:', result.data);
            }
        }
    } catch (error) {
        console.error('[loadServerChannels] Error loading channels:', error);
        console.error('[loadServerChannels] Error stack:', error.stack);
    }
    return [];
}

// Function to populate channel select - called manually via button
async function populateChannelSelect() {
    if (!SERVER_ID) {
        alert('Server ID not available. Please refresh the page.');
        console.error('[populateChannelSelect] SERVER_ID not available');
        return;
    }
    
    const channelSelect = document.getElementById('channel-select');
    const loadBtn = document.getElementById('load-channels-btn');
    
    if (!channelSelect) {
        console.error('[populateChannelSelect] Channel select element not found');
        return;
    }
    
    // Disable button and show loading state
    if (loadBtn) {
        loadBtn.disabled = true;
        loadBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
    }
    
    try {
        const channels = await loadServerChannels();
        
        if (channels.length > 0) {
            channelSelect.innerHTML = '<option value="">Select a channel</option>';
            channels.forEach(channel => {
                const option = document.createElement('option');
                option.value = channel.id;
                option.textContent = `#${channel.name}`;
                channelSelect.appendChild(option);
            });
            console.log(`[populateChannelSelect] Successfully populated ${channels.length} channels`);
            
            if (loadBtn) {
                loadBtn.innerHTML = '<i class="fas fa-check"></i> Loaded (' + channels.length + ')';
                setTimeout(() => {
                    loadBtn.disabled = false;
                    loadBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Load Channels';
                }, 2000);
            }
        } else {
            console.warn('[populateChannelSelect] No channels returned from API');
            console.warn('[populateChannelSelect] SERVER_ID:', SERVER_ID);
            console.warn('[populateChannelSelect] API URL:', getBasePath() + '/api/servers/' + SERVER_ID + '/channels');
            
            // More helpful error message
            const errorMsg = 'No channels found. This could mean:\n' +
                '1. The bot doesn\'t have permission to view channels\n' +
                '2. There are no text channels in this server\n' +
                '3. The bot is not in the server\n\n' +
                'Make sure the bot has the "View Channels" permission or "Administrator" role.';
            alert(errorMsg);
            
            if (loadBtn) {
                loadBtn.disabled = false;
                loadBtn.innerHTML = '<i class="fas fa-exclamation-triangle"></i> No Channels';
                setTimeout(() => {
                    loadBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Load Channels';
                }, 3000);
            }
        }
    } catch (error) {
        console.error('[populateChannelSelect] Error:', error);
        alert('Failed to load channels: ' + (error.message || 'Unknown error'));
        if (loadBtn) {
            loadBtn.disabled = false;
            loadBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Load Channels';
        }
    }
}

// Legacy function name for compatibility
async function loadChannels() {
    await populateChannelSelect();
    const channelSelect = document.getElementById('channel-select');
    if (channelSelect) {
        return channelSelect.options.length > 1;
    }
    return false;
}

async function loadServerRoles() {
    if (rolesLoaded) {
        return serverRoles;
    }
    if (!SERVER_ID) {
        // Don't log warning - this is called before SERVER_ID might be set
        return [];
    }
    try {
        const basePathValue = getBasePath();
        const url = basePathValue + '/api/servers/' + SERVER_ID + '/roles';
        console.log('[loadServerRoles] Fetching roles from:', url);
        
        const response = await fetch(url);
        if (!response.ok) {
            throw new Error('Failed to fetch roles: ' + response.status + ' ' + response.statusText);
        }
        const result = await response.json();
        if (result.success && Array.isArray(result.data)) {
            serverRoles = result.data;
            rolesLoaded = true;
            console.log(`[loadServerRoles] Successfully loaded ${serverRoles.length} roles`);
            return serverRoles;
        } else {
            console.warn('[loadServerRoles] Roles API returned unsuccessful response:', result);
        }
    } catch (error) {
        console.error('[loadServerRoles] Error loading roles:', error);
    }
    return [];
}

// Function to populate all role selects
async function populateRoleSelects() {
    if (!SERVER_ID) {
        // Don't log warning - SERVER_ID might not be set yet, which is fine
        return;
    }
    
    initDOMElements();
    if (!createPane) {
        console.warn('[populateRoleSelects] Create pane not found');
        return;
    }
    
    const roles = await loadServerRoles();
    
    // Populate notification role select
    const notificationRoleSelect = createPane.querySelector('#notification-role-select');
    if (notificationRoleSelect && notificationRoleSelect.options.length <= 1) {
        notificationRoleSelect.innerHTML = '<option value="">None</option>';
        roles.forEach(role => {
            const option = document.createElement('option');
            option.value = role.id;
            option.textContent = `@${role.name}`;
            notificationRoleSelect.appendChild(option);
        });
    }
    
    // Populate winner role select
    const winnerRoleSelect = createPane.querySelector('#winner-role-select');
    if (winnerRoleSelect && winnerRoleSelect.options.length <= 1) {
        winnerRoleSelect.innerHTML = '<option value="">Use server default</option>';
        roles.forEach(role => {
            const option = document.createElement('option');
            option.value = role.id;
            option.textContent = `@${role.name}`;
            winnerRoleSelect.appendChild(option);
        });
    }
}

// Function to load roles when pane becomes visible (channels load manually via button)
async function loadPaneData() {
    if (!SERVER_ID) {
        console.warn('Cannot load pane data: Server ID not available');
        return;
    }
    try {
        // Only load roles automatically, channels load via button
        await populateRoleSelects();
    } catch (error) {
        console.error('Error loading pane data:', error);
    }
}

