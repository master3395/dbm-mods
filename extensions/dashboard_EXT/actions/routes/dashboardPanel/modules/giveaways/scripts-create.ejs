// Embed field management
function addEmbedField(name = '', value = '', inline = false) {
    const fieldsList = document.getElementById('embed-fields-list');
    if (!fieldsList) return;
    
    const fieldId = 'embed-field-' + (embedFieldCounter++);
    const fieldDiv = document.createElement('div');
    fieldDiv.className = 'embed-field-item';
    fieldDiv.style.cssText = 'padding: 1rem; background: var(--surface-elevated); border-radius: var(--radius-md); margin-bottom: 0.5rem;';
    fieldDiv.innerHTML = `
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
            <input type="text" class="form-control embed-field-name" placeholder="Field name" value="${name}" maxlength="256">
            <label class="form-field form-toggle" style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" class="toggle-input embed-field-inline" ${inline ? 'checked' : ''}>
                <span class="toggle-slider"></span>
                <small>Inline</small>
            </label>
        </div>
        <textarea class="form-control embed-field-value" rows="2" placeholder="Field value" maxlength="1024">${value}</textarea>
        <button type="button" class="btn btn-sm btn-danger remove-embed-field" style="margin-top: 0.5rem;" data-field-id="${fieldId}">
            <i class="fas fa-times"></i> Remove Field
        </button>
    `;
    fieldsList.appendChild(fieldDiv);
    
    // Remove button handler
    fieldDiv.querySelector('.remove-embed-field').addEventListener('click', () => {
        fieldDiv.remove();
        updateEmbedPreview();
    });
    
    // Add change listeners
    fieldDiv.querySelector('.embed-field-name').addEventListener('input', updateEmbedPreview);
    fieldDiv.querySelector('.embed-field-value').addEventListener('input', updateEmbedPreview);
    fieldDiv.querySelector('.embed-field-inline').addEventListener('change', updateEmbedPreview);
}

