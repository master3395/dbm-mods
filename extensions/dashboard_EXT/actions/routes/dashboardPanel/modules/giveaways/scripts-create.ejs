// Initialize and set up event listeners
function initializeGiveawayCreate() {
    // Initialize DOM elements
    initDOMElements();
    
    if (!createTab || !createPane) {
        console.warn('[initializeGiveawayCreate] Create tab or pane not found, will retry...', {
            hasTab: !!createTab,
            hasPane: !!createPane
        });
        // Retry after a delay
        setTimeout(initializeGiveawayCreate, 500);
        return;
    }
    
    console.log('[initializeGiveawayCreate] Initializing giveaway create functionality');
    console.log('[initializeGiveawayCreate] SERVER_ID:', SERVER_ID);
    console.log('[initializeGiveawayCreate] basePath:', getBasePath());
    
    // Load data when tab is clicked
    createTab.addEventListener('click', function() {
        console.log('[Tab Click] Loading pane data');
        initDOMElements();
        setTimeout(loadPaneData, 50);
    });
    
    // Set up Load Channels button
    const loadChannelsBtn = document.getElementById('load-channels-btn');
    if (loadChannelsBtn) {
        loadChannelsBtn.addEventListener('click', function(e) {
            e.preventDefault();
            populateChannelSelect();
        });
    } else {
        console.warn('[initializeGiveawayCreate] Load Channels button not found');
    }
    
    // Use MutationObserver to detect when pane becomes visible
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                initDOMElements();
                if (createPane && createPane.classList.contains('active')) {
                    console.log('[MutationObserver] Pane became active, loading data');
                    setTimeout(loadPaneData, 50);
                }
            }
        });
    });
    
    observer.observe(createPane, {
        attributes: true,
        attributeFilter: ['class']
    });
    
    // Load immediately on page load if server ID is available
    if (SERVER_ID) {
        console.log('[Initial Load] Server ID available:', SERVER_ID);
        
        // Load roles automatically (channels load manually via button)
        function loadRolesNow() {
            console.log('[Initial Load] Loading roles...');
            populateRoleSelects().catch(err => console.error('[Initial Load] Error loading roles:', err));
        }
        
        // Try loading roles multiple times
        setTimeout(loadRolesNow, 100);
        setTimeout(loadRolesNow, 500);
        setTimeout(loadRolesNow, 1000);
        
        // Also load when pane becomes active
        if (createPane && createPane.classList.contains('active')) {
            console.log('[Initial Load] Pane is active, loading roles immediately');
            setTimeout(loadRolesNow, 200);
        }
        
        // Set up Load Channels button if it exists
        setTimeout(function() {
            const loadChannelsBtn = document.getElementById('load-channels-btn');
            if (loadChannelsBtn) {
                loadChannelsBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    populateChannelSelect();
                });
                console.log('[Initial Load] Load Channels button set up');
            }
        }, 500);
    } else {
        console.error('[Initial Load] ❌ SERVER_ID is not available!');
    }
}

// Start initialization when DOM is ready
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeGiveawayCreate);
} else {
    // DOM is already ready
    setTimeout(initializeGiveawayCreate, 100);
}

