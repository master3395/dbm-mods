function loadChannelsForEdit(serverId, selectedChannelId) {
    if (!serverId) return;
    
    const channelSelect = document.getElementById('edit-channelId');
    channelSelect.innerHTML = '<option value="">Loading channels...</option>';
    
    fetch(basePath + '/api/servers/' + serverId + '/channels')
        .then(res => res.json())
        .then(result => {
            if (result.success && result.data) {
                channelSelect.innerHTML = '<option value="">Select a channel...</option>';
                result.data.forEach(channel => {
                    const option = document.createElement('option');
                    option.value = channel.id;
                    option.textContent = '#' + channel.name;
                    if (channel.id === selectedChannelId) {
                        option.selected = true;
                    }
                    channelSelect.appendChild(option);
                });
            } else {
                channelSelect.innerHTML = '<option value="">Failed to load channels</option>';
            }
        })
        .catch(err => {
            console.error('Error loading channels:', err);
            channelSelect.innerHTML = '<option value="">Error loading channels</option>';
        });
}

