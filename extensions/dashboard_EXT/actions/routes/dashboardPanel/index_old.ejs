                }
                
                if (e.target.classList.contains('delete-template-btn') || e.target.closest('.delete-template-btn')) {
                    const btn = e.target.classList.contains('delete-template-btn') ? e.target : e.target.closest('.delete-template-btn');
                    const id = btn.getAttribute('data-template-id');
                    if (id) deleteTemplate(id);
                }
            });
            document._templateListenersAdded = true;
        }
        
        function deleteTemplate(id) {
            if (!id || !confirm('Are you sure you want to delete this template? This action cannot be undone.')) return;
            
            const form = document.getElementById('giveaway-create-form');
            const csrfToken = form ? form.querySelector('[name="_csrf"]')?.value : '';
            
            fetch(basePath + '/api/giveaways/templates/' + id, {
                method: 'DELETE',
                credentials: 'same-origin',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': csrfToken
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Failed to delete template: ' + (data.error || 'Unknown error'));
                }
