                const submitBtn = editForm.querySelector('button[type="submit"]');
                const formData = new FormData(editForm);
                const csrfToken = formData.get('_csrf');
                const giveawayId = formData.get('giveawayId');
                
                if (!giveawayId) {
                    feedback.className = 'form-feedback error';
                    feedback.textContent = 'Invalid giveaway ID';
                    return;
                }
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
                feedback.textContent = '';
                feedback.className = 'form-feedback';
                
                // Collect extra entries
                const extraEntries = {};
                document.querySelectorAll('.edit-extra-entry-item').forEach(item => {
                    const roleId = item.querySelector('.edit-extra-entry-role')?.value;
                    const entryCount = parseInt(item.querySelector('.edit-extra-entry-count')?.value || '0', 10);
                    if (roleId && entryCount > 0) {
                        extraEntries[roleId] = entryCount;
                    }
                });
                
                // Collect requirements
                const requirements = {};
                const reqDaily = parseInt(formData.get('reqMessagesDaily') || '0', 10);
                const reqWeekly = parseInt(formData.get('reqMessagesWeekly') || '0', 10);
                const reqMonthly = parseInt(formData.get('reqMessagesMonthly') || '0', 10);
                const reqTotal = parseInt(formData.get('reqMessagesTotal') || '0', 10);
                
                if (reqDaily > 0 || reqWeekly > 0 || reqMonthly > 0 || reqTotal > 0) {
                    requirements.messages = {};
                    if (reqDaily > 0) requirements.messages.daily = reqDaily;
                    if (reqWeekly > 0) requirements.messages.weekly = reqWeekly;
                    if (reqMonthly > 0) requirements.messages.monthly = reqMonthly;
                    if (reqTotal > 0) requirements.messages.total = reqTotal;
                }
                
                const requiredRoles = [];
                document.querySelectorAll('.edit-required-role-select').forEach(select => {
                    const roleId = select.value;
                    if (roleId) requiredRoles.push(roleId);
                });
                if (requiredRoles.length > 0) {
                    requirements.roles = requiredRoles;
                }
                
                const reqLevel = parseInt(formData.get('reqLevel') || '0', 10);
                if (reqLevel > 0) {
                    requirements.level = reqLevel;
                }
                
                const reqBypassRole = formData.get('reqBypassRole');
                if (reqBypassRole) {
                    requirements.bypassRole = reqBypassRole;
                }
                
                const blacklistedRoles = [];
                document.querySelectorAll('.edit-blacklisted-role-select').forEach(select => {
                    const roleId = select.value;
                    if (roleId) blacklistedRoles.push(roleId);
                });
                if (blacklistedRoles.length > 0) {
                    requirements.blacklistedRoles = blacklistedRoles;
                }
                
                const reqCustom = formData.get('reqCustom')?.trim();
                if (reqCustom) {
                    requirements.custom = reqCustom;
                }
                
                const updateData = {
                    prize: formData.get('prize'),
                    winners: parseInt(formData.get('winners'), 10),
                    duration: formData.get('duration'),
                    channelId: formData.get('channelId'),
                    description: formData.get('description') || '',
                    embedColor: formData.get('embedColorText'),
                    reactionEmoji: formData.get('reactionEmoji') || '🎉',
                    hostedBy: formData.get('hostedBy') || '',
                    winnerRole: formData.get('winnerRole') || null,
                    dmWinners: formData.get('dmWinners') === 'on',
                    dmHost: formData.get('dmHost') === 'on',
                    dmMessage: formData.get('dmMessage') || null,
                    dmMessageType: formData.get('dmMessageType') || 'normal',
                    pingHostInDm: formData.get('pingHostInDm') === 'on',
                    serverMessageType: formData.get('serverMessageType') || 'normal',
                    pingHostInServer: formData.get('pingHostInServer') === 'on',
                    notificationRole: formData.get('notificationRole') || null,
                    thumbnail: formData.get('thumbnail') || null,
                    image: formData.get('image') || null,
                    extraEntries: Object.keys(extraEntries).length > 0 ? extraEntries : null,
                    requirements: Object.keys(requirements).length > 0 ? requirements : null,
                    isDrop: formData.get('isDrop') === 'on',
                    entryConfirmMessage: formData.get('entryConfirmMessage') || null,
                    entryDenyMessage: formData.get('entryDenyMessage') || null,
                    entryRemoveMessage: formData.get('entryRemoveMessage') || null,
                    persistEntries: formData.get('persistEntries') === 'on',
                    removeEntriesOnEdit: formData.get('removeEntriesOnEdit') === 'on',
                    createWinnersThread: formData.get('createWinnersThread') === 'on',
                    winnersThreadType: formData.get('winnersThreadType') || 'public',
                    winnersThreadMessage: formData.get('winnersThreadMessage') || null,
                    winnersThreadCloseDuration: formData.get('winnersThreadCloseDuration') || null,
                    winnerRoleRemoveDuration: formData.get('winnerRoleRemoveDuration') || null,
                    _csrf: csrfToken
                };
                
                try {
                    const response = await fetch(basePath + '/api/giveaways/' + giveawayId, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': csrfToken
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify(updateData)
                    });
                    
                    const result = await response.json();
                    if (result.success) {
                        feedback.className = 'form-feedback success';
                        feedback.textContent = 'Giveaway updated successfully!';
                        setTimeout(() => {
                            // Reload to show updated data
                            location.reload();
                        }, 1000);
                    } else {
                        feedback.className = 'form-feedback error';
                        feedback.textContent = result.error || 'Failed to update giveaway';
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
                    }
                } catch (error) {
                    feedback.className = 'form-feedback error';
                    feedback.textContent = 'Error updating giveaway: ' + error.message;
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
                }
            });
            
            // Cancel button
            const cancelBtn = document.getElementById('cancel-edit-btn');
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function() {
                    const overviewTab = document.querySelector('[data-panel-target="giveaways-overview"]');
                    const viewEditTab = document.getElementById('view-edit-tab');
                    if (overviewTab) {
                        viewEditTab.style.display = 'none';
                        overviewTab.click();
                    }
                });
            }
            
            // End giveaway button (in edit form)
            const endBtnInForm = document.getElementById('end-giveaway-btn');
            if (endBtnInForm) {
                endBtnInForm.addEventListener('click', function() {
                    const giveawayId = document.getElementById('edit-giveaway-id').value;
                    if (giveawayId && confirm('Are you sure you want to end this giveaway?')) {
                        endGiveaway(giveawayId);
                    }
                });
            }
            
            // Color picker sync for edit form
            const editColorPicker = document.getElementById('edit-embedColor');
            const editColorText = document.getElementById('edit-embedColorText');
            if (editColorPicker && editColorText) {
                editColorPicker.addEventListener('input', () => {
                    editColorText.value = editColorPicker.value;
                });
                editColorText.addEventListener('input', () => {
                    if (/^#[0-9A-Fa-f]{6}$/i.test(editColorText.value)) {
                        editColorPicker.value = editColorText.value;
                    }
                });
            }
        }
        
        function editTemplate(id) {
            // For now, just show a message - template editing can be added later
            if (!id) return;
            
            // Load template data and populate create form for editing
            fetch(basePath + '/api/giveaways/templates/id/' + id)
                .then(res => res.json())
                .then(result => {
                    if (result.success && result.data) {
                        const template = result.data;
                        const form = document.getElementById('giveaway-create-form');
                        if (form) {
                            // Switch to create tab
                            const createTab = document.querySelector('[data-panel-target="giveaways-create"]');
                            if (createTab) {
                                createTab.click();
                            }
                            
                            // Pre-fill form with template data
                            if (template.prize) form.querySelector('[name="prize"]').value = template.prize;
                            if (template.winners) form.querySelector('[name="winners"]').value = template.winners;
                            if (template.duration) form.querySelector('[name="duration"]').value = template.duration;
                            if (template.description) form.querySelector('[name="description"]').value = template.description;
                            if (template.embedColor) {
                                form.querySelector('[name="embedColor"]').value = template.embedColor;
                                form.querySelector('[name="embedColorText"]').value = template.embedColor;
                            }
                            if (template.reactionEmoji) form.querySelector('[name="reactionEmoji"]').value = template.reactionEmoji;
                            if (template.hostedBy) form.querySelector('[name="hostedBy"]').value = template.hostedBy;
                            
                            // Load channels if serverId is available
                            if (template.serverId) {
                                const serverSelect = form.querySelector('[name="serverId"]');
                                if (serverSelect) {
                                    serverSelect.value = template.serverId;
                                    loadChannels(template.serverId, template.channelId);
                                }
                            }
                            
                            // Show success message
                            const feedback = document.getElementById('create-feedback');
                            if (feedback) {
                                feedback.className = 'form-feedback success';
                                feedback.textContent = 'Template loaded! You can now edit and save as a new template or update the existing one.';
                                setTimeout(() => {
                                    feedback.textContent = '';
                                    feedback.className = 'form-feedback';
                                }, 5000);
                            }
                        }
                    } else {
                        alert('Failed to load template: ' + (result.error || 'Unknown error'));
                    }
                })
                .catch(err => {
                    console.error('Error loading template:', err);
                    alert('Error loading template: ' + err.message);
                });
        }
        
        // Template event listeners (added after other event listeners to avoid conflicts)
        if (!document._templateListenersAdded) {
            document.addEventListener('click', function(e) {
                if (e.target.classList.contains('use-template-btn') || e.target.closest('.use-template-btn')) {
                    const btn = e.target.classList.contains('use-template-btn') ? e.target : e.target.closest('.use-template-btn');
                    const id = btn.getAttribute('data-template-id');
                    if (id) useTemplate(id);
