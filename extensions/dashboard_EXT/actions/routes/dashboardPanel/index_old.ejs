            loadServerRoles().then(roles => {
                roles.forEach(role => {
                    const option = document.createElement('option');
                    option.value = role.id;
                    option.textContent = `@${role.name}`;
                    if (role.id === roleId) option.selected = true;
                    roleSelect.appendChild(option);
                });
            });
            
            // Remove button handler
            entryDiv.querySelector('.remove-default-extra-entry').addEventListener('click', () => {
                entryDiv.remove();
            });
        }
        
        if (addDefaultExtraEntryBtn) {
            addDefaultExtraEntryBtn.addEventListener('click', () => addDefaultExtraEntry());
        }

        // Settings form submission
        const settingsForm = document.getElementById('giveaway-settings-form');
        if (settingsForm) {
            settingsForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                const feedback = document.getElementById('settings-feedback');
                const submitBtn = settingsForm.querySelector('button[type="submit"]');
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
                feedback.textContent = '';
                feedback.className = 'form-feedback';

                const formData = new FormData(settingsForm);
                
                // Collect creator roles (max 5)
                const creatorRoles = Array.from(settingsForm.querySelector('#creator-roles-select')?.selectedOptions || [])
                    .map(opt => opt.value)
                    .slice(0, 5);
                
                // Collect manager roles (max 5)
                const managerRoles = Array.from(settingsForm.querySelector('#manager-roles-select')?.selectedOptions || [])
                    .map(opt => opt.value)
                    .slice(0, 5);
                
                // Collect default extra entries
                const defaultExtraEntries = {};
                document.querySelectorAll('.default-extra-entry-item').forEach(item => {
                    const roleId = item.querySelector('.default-extra-entry-role')?.value;
                    const entryCount = parseInt(item.querySelector('.default-extra-entry-count')?.value || '0', 10);
                    if (roleId && entryCount > 0) {
                        defaultExtraEntries[roleId] = entryCount;
                    }
                });
                
                const settings = {
                    prefix: formData.get('prefix') || '!',
                    language: formData.get('language') || 'en',
                    creatorRoles: creatorRoles,
                    managerRoles: managerRoles,
                    dmGiveawayHost: formData.get('dmGiveawayHost') === 'on',
                    dmGiveawayWinners: formData.get('dmGiveawayWinners') === 'on',
                    winnerRole: formData.get('winnerRole') || null,
                    showCaptcha: formData.get('showCaptcha') === 'on',
                    publicGiveaways: formData.get('publicGiveaways') === 'on',
                    defaultExtraEntries: Object.keys(defaultExtraEntries).length > 0 ? defaultExtraEntries : {},
                    defaultEmbedColor: formData.get('defaultEmbedColorText'),
                    defaultEndEmbedColor: formData.get('defaultEndEmbedColorText'),
                    defaultHost: formData.get('defaultHost') || null,
                    defaultCreateMessage: formData.get('defaultCreateMessage')
                };

                try {
                    const response = await fetch(basePath + '/api/giveaways/settings/' + formData.get('serverId'), {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify(settings)
                    });

                    const result = await response.json();
                    if (result.success) {
                        feedback.className = 'form-feedback success';
                        feedback.textContent = 'Settings saved successfully!';
                    } else {
                        feedback.className = 'form-feedback error';
                        feedback.textContent = result.error || 'Failed to save settings';
                    }
                } catch (error) {
                    feedback.className = 'form-feedback error';
                    feedback.textContent = 'Error saving settings: ' + error.message;
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-save"></i> Save Settings';
                }
            });
        }

        // Color picker sync
        document.querySelectorAll('.color-picker').forEach(picker => {
            const textInput = picker.parentElement.querySelector('.color-text');
            if (textInput) {
                picker.addEventListener('input', () => {
                    textInput.value = picker.value;
                });
                textInput.addEventListener('input', () => {
                    if (/^#[0-9A-Fa-f]{6}$/i.test(textInput.value)) {
                        picker.value = textInput.value;
                    }
                });
            }
        });

        updateTimeElements();
        setInterval(updateTimeElements, 60000); // Update every minute

        // Load channels and roles when create pane is shown
        const createPane = document.getElementById('giveaways-create');
        const createTab = document.querySelector('[data-panel-target="giveaways-create"]');
        let rolesLoaded = false;
        let serverRoles = [];
        
        async function loadServerRoles() {
            if (rolesLoaded) return serverRoles;
            try {
                const response = await fetch(basePath + '/api/servers/<%= data.server.id %>/roles');
                const result = await response.json();
                if (result.success && Array.isArray(result.data)) {
                    serverRoles = result.data;
                    rolesLoaded = true;
                    return serverRoles;
                }
            } catch (error) {
                console.error('Error loading roles:', error);
            }
            return [];
        }
        
        if (createTab && createPane) {
            createTab.addEventListener('click', async function() {
                const channelSelect = createPane.querySelector('select[name="channelId"]');
                if (channelSelect && channelSelect.options.length === 1) {
                    // Load channels for the server
                    try {
                        const response = await fetch(basePath + '/api/servers/<%= data.server.id %>/channels');
                        const result = await response.json();
                        if (result.success && Array.isArray(result.data)) {
                            channelSelect.innerHTML = '<option value="">Select a channel</option>';
                            result.data.forEach(channel => {
                                if (channel.type === 0) { // Text channel
                                    const option = document.createElement('option');
                                    option.value = channel.id;
                                    option.textContent = `#${channel.name}`;
                                    channelSelect.appendChild(option);
                                }
                            });
                        }
                    } catch (error) {
                        console.error('Error loading channels:', error);
                    }
                }
                
                // Load roles for winner role select
                const winnerRoleSelect = createPane.querySelector('#winner-role-select');
                if (winnerRoleSelect && winnerRoleSelect.options.length <= 1) {
                    const roles = await loadServerRoles();
                    roles.forEach(role => {
                        const option = document.createElement('option');
                        option.value = role.id;
                        option.textContent = `@${role.name}`;
                        winnerRoleSelect.appendChild(option);
                    });
                }
            });
        }
        
        // Extra entries management
        let extraEntryCounter = 0;
        const extraEntriesList = document.getElementById('extra-entries-list');
        const addExtraEntryBtn = document.getElementById('add-extra-entry-btn');
        
        function addExtraEntry(roleId = '', entryCount = 1) {
            const entryId = 'extra-entry-' + (extraEntryCounter++);
            const entryDiv = document.createElement('div');
            entryDiv.className = 'extra-entry-item';
            entryDiv.style.cssText = 'display: flex; gap: 1rem; align-items: center; padding: 1rem; background: var(--surface-elevated); border-radius: var(--radius-md); margin-bottom: 0.5rem;';
            entryDiv.innerHTML = `
                <select class="form-control extra-entry-role" style="flex: 1;" data-entry-id="${entryId}">
                    <option value="">Select role...</option>
                </select>
                <input type="number" class="form-control extra-entry-count" value="${entryCount}" min="1" max="250" style="width: 120px;" placeholder="Entries">
                <button type="button" class="btn btn-sm btn-danger remove-extra-entry" data-entry-id="${entryId}">
                    <i class="fas fa-times"></i>
                </button>
            `;
            extraEntriesList.appendChild(entryDiv);
            
            // Populate role select
            const roleSelect = entryDiv.querySelector('.extra-entry-role');
            loadServerRoles().then(roles => {
                roles.forEach(role => {
                    const option = document.createElement('option');
                    option.value = role.id;
                    option.textContent = `@${role.name}`;
                    if (role.id === roleId) option.selected = true;
                    roleSelect.appendChild(option);
                });
            });
            
            // Remove button handler
            entryDiv.querySelector('.remove-extra-entry').addEventListener('click', () => {
                entryDiv.remove();
            });
        }
        
        if (addExtraEntryBtn) {
            addExtraEntryBtn.addEventListener('click', () => addExtraEntry());
        }
        
        // Required roles management
        let requiredRoleCounter = 0;
        const requiredRolesList = document.getElementById('required-roles-list');
        const addRequiredRoleBtn = document.getElementById('add-required-role-btn');
        
        function addRequiredRole(roleId = '') {
            const roleItemId = 'required-role-' + (requiredRoleCounter++);
            const roleDiv = document.createElement('div');
            roleDiv.className = 'required-role-item';
            roleDiv.style.cssText = 'display: flex; gap: 1rem; align-items: center; padding: 0.75rem; background: var(--surface); border-radius: var(--radius-sm); margin-bottom: 0.5rem;';
            roleDiv.innerHTML = `
                <select class="form-control required-role-select" style="flex: 1;" data-role-id="${roleItemId}">
                    <option value="">Select role...</option>
                </select>
                <button type="button" class="btn btn-sm btn-danger remove-required-role" data-role-id="${roleItemId}">
                    <i class="fas fa-times"></i>
                </button>
            `;
            requiredRolesList.appendChild(roleDiv);
            
            // Populate role select
            const roleSelect = roleDiv.querySelector('.required-role-select');
            loadServerRoles().then(roles => {
                roles.forEach(role => {
                    const option = document.createElement('option');
                    option.value = role.id;
                    option.textContent = `@${role.name}`;
                    if (role.id === roleId) option.selected = true;
                    roleSelect.appendChild(option);
                });
            });
            
            // Remove button handler
            roleDiv.querySelector('.remove-required-role').addEventListener('click', () => {
                roleDiv.remove();
            });
        }
        
        if (addRequiredRoleBtn) {
            addRequiredRoleBtn.addEventListener('click', () => addRequiredRole());
        }
        
        // Blacklisted roles management
        let blacklistedRoleCounter = 0;
        const blacklistedRolesList = document.getElementById('blacklisted-roles-list');
        const addBlacklistedRoleBtn = document.getElementById('add-blacklisted-role-btn');
        
        function addBlacklistedRole(roleId = '') {
            const roleItemId = 'blacklisted-role-' + (blacklistedRoleCounter++);
            const roleDiv = document.createElement('div');
            roleDiv.className = 'blacklisted-role-item';
            roleDiv.style.cssText = 'display: flex; gap: 1rem; align-items: center; padding: 0.75rem; background: var(--surface); border-radius: var(--radius-sm); margin-bottom: 0.5rem;';
            roleDiv.innerHTML = `
                <select class="form-control blacklisted-role-select" style="flex: 1;" data-role-id="${roleItemId}">
                    <option value="">Select role...</option>
                </select>
                <button type="button" class="btn btn-sm btn-danger remove-blacklisted-role" data-role-id="${roleItemId}">
                    <i class="fas fa-times"></i>
                </button>
            `;
            blacklistedRolesList.appendChild(roleDiv);
            
            // Populate role select
            const roleSelect = roleDiv.querySelector('.blacklisted-role-select');
            loadServerRoles().then(roles => {
                roles.forEach(role => {
                    const option = document.createElement('option');
                    option.value = role.id;
                    option.textContent = `@${role.name}`;
                    if (role.id === roleId) option.selected = true;
                    roleSelect.appendChild(option);
                });
            });
            
            // Remove button handler
            roleDiv.querySelector('.remove-blacklisted-role').addEventListener('click', () => {
                roleDiv.remove();
            });
        }
        
        if (addBlacklistedRoleBtn) {
            addBlacklistedRoleBtn.addEventListener('click', () => addBlacklistedRole());
        }
        
        // Populate bypass role select
        const reqBypassRoleSelect = document.getElementById('req-bypass-role-select');
        if (reqBypassRoleSelect) {
            loadServerRoles().then(roles => {
                roles.forEach(role => {
                    const option = document.createElement('option');
                    option.value = role.id;
                    option.textContent = `@${role.name}`;
                    reqBypassRoleSelect.appendChild(option);
                });
            });
        }
        
        // Winners thread toggle
        const createWinnersThreadCheckbox = document.getElementById('create-winners-thread-checkbox');
        const winnersThreadOptions = document.getElementById('winners-thread-options');
        if (createWinnersThreadCheckbox && winnersThreadOptions) {
            createWinnersThreadCheckbox.addEventListener('change', function() {
                winnersThreadOptions.style.display = this.checked ? 'block' : 'none';
            });
        }

        // Create giveaway form submission
        const createForm = document.getElementById('giveaway-create-form');
        if (createForm) {
            let isSubmitting = false; // Prevent double-submit
            
            createForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                // Prevent double-submit
                if (isSubmitting) {
                    console.warn('Form submission already in progress');
                    return;
                }
                
                isSubmitting = true;
                const feedback = document.getElementById('create-feedback');
                const submitBtn = createForm.querySelector('button[type="submit"]');
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';
                feedback.textContent = '';
                feedback.className = 'form-feedback';

                const formData = new FormData(createForm);
                const csrfToken = formData.get('_csrf');
                
                // Collect extra entries
                const extraEntries = {};
                document.querySelectorAll('.extra-entry-item').forEach(item => {
                    const roleId = item.querySelector('.extra-entry-role')?.value;
                    const entryCount = parseInt(item.querySelector('.extra-entry-count')?.value || '0', 10);
                    if (roleId && entryCount > 0) {
                        extraEntries[roleId] = entryCount;
                    }
                });
                
                // Collect requirements
                const requirements = {};
                const reqDaily = parseInt(formData.get('reqMessagesDaily') || '0', 10);
                const reqWeekly = parseInt(formData.get('reqMessagesWeekly') || '0', 10);
                const reqMonthly = parseInt(formData.get('reqMessagesMonthly') || '0', 10);
                const reqTotal = parseInt(formData.get('reqMessagesTotal') || '0', 10);
                
                if (reqDaily > 0 || reqWeekly > 0 || reqMonthly > 0 || reqTotal > 0) {
                    requirements.messages = {};
                    if (reqDaily > 0) requirements.messages.daily = reqDaily;
                    if (reqWeekly > 0) requirements.messages.weekly = reqWeekly;
                    if (reqMonthly > 0) requirements.messages.monthly = reqMonthly;
                    if (reqTotal > 0) requirements.messages.total = reqTotal;
                }
                
                const requiredRoles = [];
                document.querySelectorAll('.required-role-select').forEach(select => {
                    const roleId = select.value;
                    if (roleId) requiredRoles.push(roleId);
                });
                if (requiredRoles.length > 0) {
                    requirements.roles = requiredRoles;
                }
                
                const reqLevel = parseInt(formData.get('reqLevel') || '0', 10);
                if (reqLevel > 0) {
                    requirements.level = reqLevel;
                }
                
                const reqBypassRole = formData.get('reqBypassRole');
                if (reqBypassRole) {
                    requirements.bypassRole = reqBypassRole;
                }
                
                const blacklistedRoles = [];
                document.querySelectorAll('.blacklisted-role-select').forEach(select => {
                    const roleId = select.value;
                    if (roleId) blacklistedRoles.push(roleId);
                });
                if (blacklistedRoles.length > 0) {
                    requirements.blacklistedRoles = blacklistedRoles;
                }
                
                const reqCustom = formData.get('reqCustom')?.trim();
                if (reqCustom) {
                    requirements.custom = reqCustom;
                }
                
                const giveawayData = {
                    serverId: formData.get('serverId'),
                    prize: formData.get('prize'),
                    winners: parseInt(formData.get('winners'), 10),
                    duration: formData.get('duration'),
                    channelId: formData.get('channelId'),
                    description: formData.get('description') || '',
                    embedColor: formData.get('embedColorText'),
                    reactionEmoji: formData.get('reactionEmoji') || '🎉',
                    hostedBy: formData.get('hostedBy') || '',
                    scheduled: formData.get('scheduled') === 'on',
                    scheduledStart: formData.get('scheduledStart') ? new Date(formData.get('scheduledStart')).getTime() : null,
                    winnerRole: formData.get('winnerRole') || null,
                    dmWinners: formData.get('dmWinners') === 'on',
                    dmHost: formData.get('dmHost') === 'on',
                    dmMessage: formData.get('dmMessage') || null,
                    dmMessageType: formData.get('dmMessageType') || 'normal',
                    pingHostInDm: formData.get('pingHostInDm') === 'on',
                    serverMessageType: formData.get('serverMessageType') || 'normal',
                    pingHostInServer: formData.get('pingHostInServer') === 'on',
                    notificationRole: formData.get('notificationRole') || null,
                    thumbnail: formData.get('thumbnail') || null,
                    image: formData.get('image') || null,
                    extraEntries: Object.keys(extraEntries).length > 0 ? extraEntries : null,
                    requirements: Object.keys(requirements).length > 0 ? requirements : null,
                    isDrop: formData.get('isDrop') === 'on',
                    entryConfirmMessage: formData.get('entryConfirmMessage') || null,
                    entryDenyMessage: formData.get('entryDenyMessage') || null,
                    entryRemoveMessage: formData.get('entryRemoveMessage') || null,
                    persistEntries: formData.get('persistEntries') === 'on',
                    removeEntriesOnEdit: formData.get('removeEntriesOnEdit') === 'on',
                    createWinnersThread: formData.get('createWinnersThread') === 'on',
                    winnersThreadType: formData.get('winnersThreadType') || 'public',
                    winnersThreadMessage: formData.get('winnersThreadMessage') || null,
                    winnersThreadCloseDuration: formData.get('winnersThreadCloseDuration') || null,
                    winnerRoleRemoveDuration: formData.get('winnerRoleRemoveDuration') || null,
                    _csrf: csrfToken // Include CSRF token in body
                };

                try {
                    const response = await fetch(basePath + '/api/giveaways/create', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': csrfToken // Also include as header
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify(giveawayData)
                    });

                    const result = await response.json();
                    if (result.success) {
                        feedback.className = 'form-feedback success';
                        feedback.textContent = 'Giveaway created successfully!';
                        createForm.reset();
                        // Switch to overview tab after 1 second
                        setTimeout(() => {
                            const overviewTab = document.querySelector('[data-panel-target="giveaways-overview"]');
                            if (overviewTab) {
                                overviewTab.click();
                                location.reload();
                            }
                        }, 1000);
                    } else {
                        feedback.className = 'form-feedback error';
                        feedback.textContent = result.error || 'Failed to create giveaway';
                    }
                } catch (error) {
                    feedback.className = 'form-feedback error';
                    feedback.textContent = 'Error creating giveaway: ' + error.message;
                } finally {
                    isSubmitting = false;
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-plus"></i> Create Giveaway';
                }
            });
            
            // Save as Template button handler
            const saveTemplateBtn = document.getElementById('save-template-btn');
            if (saveTemplateBtn) {
                saveTemplateBtn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    const feedback = document.getElementById('create-feedback');
                    const formData = new FormData(createForm);
                    const csrfToken = formData.get('_csrf');
                    
                    const templateData = {
                        name: formData.get('prize') || 'Untitled Template',
                        serverId: formData.get('serverId'),
                        prize: formData.get('prize'),
                        winners: parseInt(formData.get('winners'), 10) || 1,
                        duration: formData.get('duration') || '7d',
                        description: formData.get('description') || '',
                        embedColor: formData.get('embedColorText') || '#338ac4',
                        reactionEmoji: formData.get('reactionEmoji') || '🎉',
                        hostedBy: formData.get('hostedBy') || '',
                        _csrf: csrfToken
                    };
                    
                    try {
                        const response = await fetch(basePath + '/api/giveaways/templates', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-Token': csrfToken
                            },
                            credentials: 'same-origin',
                            body: JSON.stringify(templateData)
                        });
                        
                        const result = await response.json();
                        if (result.success) {
                            feedback.className = 'form-feedback success';
                            feedback.textContent = 'Template saved successfully!';
                            setTimeout(() => {
                                feedback.textContent = '';
                                feedback.className = 'form-feedback';
                            }, 3000);
                        } else {
                            feedback.className = 'form-feedback error';
                            feedback.textContent = result.error || 'Failed to save template';
                        }
                    } catch (error) {
                        feedback.className = 'form-feedback error';
                        feedback.textContent = 'Error saving template: ' + error.message;
                    }
                });
            }

            // Schedule checkbox toggle
            const scheduledCheckbox = createForm.querySelector('#scheduled-checkbox');
            const scheduleOptions = createForm.querySelector('#schedule-options');
            if (scheduledCheckbox && scheduleOptions) {
                scheduledCheckbox.addEventListener('change', function() {
                    scheduleOptions.style.display = this.checked ? 'block' : 'none';
                    if (this.checked) {
                        const now = new Date();
                        now.setMinutes(now.getMinutes() + 30); // Default to 30 minutes from now
                        const datetimeLocal = now.toISOString().slice(0, 16);
                        createForm.querySelector('[name="scheduledStart"]').value = datetimeLocal;
                    }
                });
            }

            // Color picker sync
            const colorPicker = createForm.querySelector('[name="embedColor"]');
            const colorText = createForm.querySelector('[name="embedColorText"]');
            if (colorPicker && colorText) {
                colorPicker.addEventListener('input', () => {
                    colorText.value = colorPicker.value;
                });
                colorText.addEventListener('input', () => {
                    if (/^#[0-9A-Fa-f]{6}$/i.test(colorText.value)) {
                        colorPicker.value = colorText.value;
                    }
                });
            }
        }
        <% } // End EJS conditional: giveaway system JavaScript %>
    </script>
</body>
</html>