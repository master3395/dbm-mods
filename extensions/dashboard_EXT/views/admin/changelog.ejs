<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.seo?.title || 'Changelog Management - News Targeted Bot' %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/shared/styles.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        .admin-header {
            margin-bottom: 2rem;
        }
        .admin-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.5rem;
        }
        .admin-header p {
            color: #9ca3af;
        }
        .form-section {
            background: #1f2937;
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .form-section h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 1rem;
        }
        .form-group {
            margin-bottom: 1rem;
        }
        .form-group label {
            display: block;
            color: #d1d5db;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            background: #374151;
            border: 1px solid #4b5563;
            border-radius: 0.375rem;
            color: #fff;
            font-size: 0.875rem;
        }
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #60a5fa;
        }
        .form-group textarea {
            min-height: 100px;
            resize: vertical;
        }
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.375rem;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-primary {
            background: #3b82f6;
            color: #fff;
        }
        .btn-primary:hover {
            background: #2563eb;
        }
        .btn-danger {
            background: #ef4444;
            color: #fff;
        }
        .btn-danger:hover {
            background: #dc2626;
        }
        .btn-secondary {
            background: #6b7280;
            color: #fff;
        }
        .btn-secondary:hover {
            background: #4b5563;
        }
        .entries-list {
            margin-top: 2rem;
        }
        .entry-card {
            background: #1f2937;
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            border: 1px solid #374151;
        }
        .entry-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        .entry-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: #fff;
        }
        .entry-meta {
            color: #9ca3af;
            font-size: 0.875rem;
        }
        .entry-actions {
            display: flex;
            gap: 0.5rem;
        }
        .category-section {
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #374151;
        }
        .category-section h4 {
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 0.5rem;
        }
        .category-section ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .category-section li {
            color: #d1d5db;
            font-size: 0.875rem;
            margin-bottom: 0.25rem;
        }
        .alert {
            padding: 1rem;
            border-radius: 0.375rem;
            margin-bottom: 1rem;
        }
        .alert-success {
            background: #065f46;
            color: #d1fae5;
            border: 1px solid #10b981;
        }
        .alert-error {
            background: #7f1d1d;
            color: #fecaca;
            border: 1px solid #ef4444;
        }
        .categories-editor {
            margin-top: 1rem;
        }
        .category-item {
            background: #374151;
            border-radius: 0.375rem;
            padding: 1rem;
            margin-bottom: 1rem;
        }
        .category-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .category-item-header input {
            flex: 1;
            margin-right: 0.5rem;
        }
        .category-items-list {
            margin-top: 0.5rem;
        }
        .category-item-input {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }
        .category-item-input input {
            flex: 1;
        }
    </style>
</head>
<body class="main-layout">
    <%- include('../shared/header', { data: data }) %>

    <main class="admin-container">
        <div class="admin-header">
            <h1><i class="fas fa-history mr-2"></i>Changelog Management</h1>
            <p>Add, edit, and manage changelog entries for the dashboard</p>
        </div>

        <div id="alert-container"></div>

        <div class="form-section">
            <h2>Add New Changelog Entry</h2>
            <form id="changelog-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="version">Version *</label>
                        <input type="text" id="version" name="version" placeholder="2.1.8" required>
                    </div>
                    <div class="form-group">
                        <label for="date">Date *</label>
                        <input type="date" id="date" name="date" required>
                    </div>
                    <div class="form-group">
                        <label for="time">Time</label>
                        <input type="time" id="time" name="time">
                    </div>
                    <div class="form-group">
                        <label for="type">Type *</label>
                        <select id="type" name="type" required>
                            <option value="patch">Patch</option>
                            <option value="minor">Minor</option>
                            <option value="major">Major</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" placeholder="Optional title for this version">
                </div>
                <div class="form-group">
                    <label>Categories</label>
                    <div class="categories-editor" id="categories-editor">
                        <div class="category-item">
                            <div class="category-item-header">
                                <input type="text" placeholder="Category name (e.g., Fixed, Added, Changed)" class="category-name">
                                <button type="button" class="btn btn-danger" onclick="removeCategory(this)"><i class="fas fa-trash"></i></button>
                            </div>
                            <div class="category-items-list">
                                <div class="category-item-input">
                                    <input type="text" placeholder="Item description" class="category-item-text">
                                    <button type="button" class="btn btn-secondary" onclick="removeCategoryItem(this)"><i class="fas fa-times"></i></button>
                                </div>
                            </div>
                            <button type="button" class="btn btn-secondary" onclick="addCategoryItem(this)" style="margin-top: 0.5rem;"><i class="fas fa-plus"></i> Add Item</button>
                        </div>
                    </div>
                    <button type="button" class="btn btn-secondary" onclick="addCategory()" style="margin-top: 1rem;"><i class="fas fa-plus"></i> Add Category</button>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Entry</button>
                </div>
            </form>
        </div>

        <div class="entries-list">
            <h2 style="color: #fff; margin-bottom: 1rem;">Existing Entries</h2>
            <div id="entries-container">
                <% if (data.changelog && data.changelog.entries && data.changelog.entries.length > 0) { %>
                    <% data.changelog.entries.forEach(entry => { %>
                        <div class="entry-card" data-version="<%= entry.version %>">
                            <div class="entry-header">
                                <div>
                                    <div class="entry-title">Version <%= entry.version %></div>
                                    <div class="entry-meta">
                                        <%= entry.date %> <%= entry.time || '' %> · 
                                        <span style="text-transform: capitalize;"><%= entry.type %></span>
                                        <% if (entry.title) { %> · <%= entry.title %><% } %>
                                    </div>
                                </div>
                                <div class="entry-actions">
                                    <button class="btn btn-danger" onclick="deleteEntry('<%= entry.version %>')"><i class="fas fa-trash"></i> Delete</button>
                                </div>
                            </div>
                            <% if (entry.categories) { %>
                                <% Object.keys(entry.categories).forEach(category => { %>
                                    <div class="category-section">
                                        <h4><%= category %></h4>
                                        <ul>
                                            <% entry.categories[category].forEach(item => { %>
                                                <li><i class="fas fa-check" style="color: #10b981; margin-right: 0.5rem;"></i><%= item %></li>
                                            <% }); %>
                                        </ul>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color: #9ca3af; text-align: center; padding: 2rem;">No changelog entries yet. Add your first entry above.</p>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('../shared/footer', { data: data }) %>

    <script>
        // Set default date to today
        document.getElementById('date').valueAsDate = new Date();
        document.getElementById('time').value = new Date().toTimeString().slice(0, 5);

        function addCategory() {
            const editor = document.getElementById('categories-editor');
            const categoryHtml = `
                <div class="category-item">
                    <div class="category-item-header">
                        <input type="text" placeholder="Category name (e.g., Fixed, Added, Changed)" class="category-name">
                        <button type="button" class="btn btn-danger" onclick="removeCategory(this)"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="category-items-list">
                        <div class="category-item-input">
                            <input type="text" placeholder="Item description" class="category-item-text">
                            <button type="button" class="btn btn-secondary" onclick="removeCategoryItem(this)"><i class="fas fa-times"></i></button>
                        </div>
                    </div>
                    <button type="button" class="btn btn-secondary" onclick="addCategoryItem(this)" style="margin-top: 0.5rem;"><i class="fas fa-plus"></i> Add Item</button>
                </div>
            `;
            editor.insertAdjacentHTML('beforeend', categoryHtml);
        }

        function removeCategory(button) {
            button.closest('.category-item').remove();
        }

        function addCategoryItem(button) {
            const list = button.previousElementSibling;
            const itemHtml = `
                <div class="category-item-input">
                    <input type="text" placeholder="Item description" class="category-item-text">
                    <button type="button" class="btn btn-secondary" onclick="removeCategoryItem(this)"><i class="fas fa-times"></i></button>
                </div>
            `;
            list.insertAdjacentHTML('beforeend', itemHtml);
        }

        function removeCategoryItem(button) {
            button.closest('.category-item-input').remove();
        }

        function showAlert(message, type = 'success') {
            const container = document.getElementById('alert-container');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            alert.textContent = message;
            container.appendChild(alert);
            setTimeout(() => alert.remove(), 5000);
        }

        document.getElementById('changelog-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const categories = {};
            
            document.querySelectorAll('.category-item').forEach(categoryItem => {
                const categoryName = categoryItem.querySelector('.category-name').value.trim();
                if (categoryName) {
                    const items = [];
                    categoryItem.querySelectorAll('.category-item-text').forEach(input => {
                        const value = input.value.trim();
                        if (value) items.push(value);
                    });
                    if (items.length > 0) {
                        categories[categoryName] = items;
                    }
                }
            });

            const entry = {
                version: formData.get('version'),
                date: formData.get('date'),
                time: formData.get('time') || new Date().toTimeString().slice(0, 5),
                type: formData.get('type'),
                title: formData.get('title') || '',
                categories: categories
            };

            try {
                const response = await fetch('/api/changelog', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(entry)
                });

                const result = await response.json();
                
                if (result.success) {
                    showAlert('Changelog entry added successfully!', 'success');
                    e.target.reset();
                    document.getElementById('date').valueAsDate = new Date();
                    document.getElementById('time').value = new Date().toTimeString().slice(0, 5);
                    document.getElementById('categories-editor').innerHTML = '';
                    addCategory();
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showAlert(result.message || 'Failed to add changelog entry', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('An error occurred while saving the entry', 'error');
            }
        });

        async function deleteEntry(version) {
            if (!confirm(`Are you sure you want to delete version ${version}?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/changelog/${encodeURIComponent(version)}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                
                if (result.success) {
                    showAlert('Changelog entry deleted successfully!', 'success');
                    document.querySelector(`[data-version="${version}"]`).remove();
                } else {
                    showAlert(result.message || 'Failed to delete changelog entry', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('An error occurred while deleting the entry', 'error');
            }
        }

        // Initialize with one category
        addCategory();
    </script>
</body>
</html>

