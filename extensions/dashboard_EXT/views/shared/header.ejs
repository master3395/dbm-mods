<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% const seoDefaults = data.seoDefaults || {}; %>
    <% const seo = data.seo || {}; %>
    <% const currentPath = data.currentPath || '/'; %>
    <% const computedTitle = seo.title || data.title || seoDefaults.defaultTitle || 'News Targeted Bot Dashboard'; %>
    <% const computedDescription = seo.description || data.description || seoDefaults.defaultDescription || 'Professional Discord Bot Dashboard by News Targeted'; %>
    <% const computedKeywords = seo.keywords || seoDefaults.defaultKeywords || 'discord, bot, dashboard, management, news targeted'; %>
    <% const computedImage = seo.image || seoDefaults.defaultImage || '/images/social-card.png'; %>
    <% const canonicalBase = seoDefaults.canonicalBase ? seoDefaults.canonicalBase.replace(/\/$/, '') : null; %>
    <% const computedCanonical = seo.canonical || (canonicalBase ? `${canonicalBase}${currentPath}` : null); %>
    <% const twitterHandle = seoDefaults.twitterHandle || ''; %>
    <title><%= computedTitle %></title>
    
    <% 
    // basePath is set by middleware in res.locals.basePath
    // Express automatically merges res.locals into template context
    // Use a different variable name to avoid circular reference
    const templateBasePath = (typeof basePath !== 'undefined' && basePath) ? basePath : '';
    // Always show giveaway button - system is backward compatible
    // Default to true to allow users to initialize the system
    const giveawaySystemAvailable = typeof data.giveawaySystemAvailable !== 'undefined' 
        ? (data.giveawaySystemAvailable !== false) 
        : true;
    %>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="<%= templateBasePath %>/favicon.ico">
    <% if (computedCanonical) { %>
    <link rel="canonical" href="<%= computedCanonical %>">
    <% } %>
    
    <!-- CSS -->
    <link rel="stylesheet" href="<%= templateBasePath %>/shared/styles.css">
    
    <!-- AOS Animation Library -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Meta Tags -->
    <meta name="description" content="<%= computedDescription %>">
    <meta name="keywords" content="<%= computedKeywords %>">
    <meta name="author" content="Master3395 / News Targeted">
    
    <!-- Open Graph -->
    <meta property="og:title" content="<%= computedTitle %>">
    <meta property="og:description" content="<%= computedDescription %>">
    <meta property="og:image" content="<%= computedImage %>">
    <% if (computedCanonical) { %>
    <meta property="og:url" content="<%= computedCanonical %>">
    <% } %>
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= computedTitle %>">
    <meta name="twitter:description" content="<%= computedDescription %>">
    <meta name="twitter:image" content="<%= computedImage %>">
    <% if (twitterHandle) { %>
    <meta name="twitter:site" content="<%= twitterHandle %>">
    <% } %>
    <% const csrfValue = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>
    <script>
        window.DashboardCsrfToken = "<%= csrfValue %>";
    </script>
</head>
<%- include('../shared/sidebar.ejs', { data: data }) %>
    <div class="main-with-sidebar">
        <header class="topbar topbar-minimal">
            <button type="button" id="sidebarToggle" class="topbar-toggle" aria-label="Open menu"><i class="fas fa-bars"></i></button>
        </header>