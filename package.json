{
  "$schema": "https://json.schemastore.org/package",
  "name": "discord-bot-maker-bot",
  "author": "Robert Borghese",
  "main": "bot.js",
  "version": "2.1.7",
  "description": "DBM Mods / bot dependencies (beta_branch_2.2) — includes CI lint scripts for GitHub Actions.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "lint": "eslint --cache actions events extensions sharder",
    "lint:fix": "eslint --fix --cache actions events extensions sharder",
    "lint:ts": "eslint --cache bot.ts types.ts \"actions/**/*.ts\" \"extensions/**/*.ts\"",
    "lint:ts:fix": "eslint --fix --cache bot.ts types.ts \"actions/**/*.ts\" \"extensions/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:bot": "npm run typecheck && npm run lint:ts",
    "lint:all": "npm run lint && npm run lint:ts",
    "prettier:check": "prettier --check **/*.{js,json,yml,ts}",
    "prettier:fix": "prettier --write **/*.{js,json,yml,ts}"
  },
  "engines": {
    "node": ">=22.0.0 <27.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.1",
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@top-gg/sdk": "^3.1.6",
    "@xmldom/xmldom": "^0.8.12",
    "axios": "^1.15.0",
    "chalk": "^5.3.0",
    "chart.js": "^4.4.3",
    "discord-player": "^7.1.0",
    "discord.js": "14.26.2",
    "express": "^5.1.0",
    "fast-sort": "^3.4.1",
    "feed-watcher": "^0.2.1",
    "ffmpeg-static": "^5.2.0",
    "fs-extra": "^11.2.0",
    "fstorm": "^0.1.3",
    "google-it": "^1.6.4",
    "imagedata-filters": "^1.0.1",
    "insert-line": "^1.1.0",
    "jimp": "^1.6.0",
    "jsonpath-plus": "^10.4.0",
    "loadavg-windows": "^1.1.1",
    "mysql2": "^3.11.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "node-google-translate-skidz": "^1.1.2",
    "node-html-parser": "^6.1.13",
    "nodemailer": "^8.0.5",
    "normalize-date": "^0.0.4",
    "opentype.js": "^1.3.4",
    "pixel-gif": "^0.0.1",
    "play-dl": "^1.9.7",
    "sequelize": "^6.37.8",
    "simple-youtube-api": "^5.2.1",
    "tesseract.js": "^7.0.0",
    "tweetnacl": "^1.0.3",
    "xml2js": "^0.6.2",
    "xpath": "^0.0.34",
    "youtube-dl-exec": "^3.0.27",
    "youtubei": "^1.5.3",
    "ytdl-core": "^4.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "discord.js": "^14.26.2",
    "eslint": "^8.0.1",
    "eslint-config-aqua": "9.0.2",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.8.8",
    "typescript": "~5.4.0"
  },
  "overrides": {
    "form-data": "^2.5.4",
    "tough-cookie": "^4.1.3",
    "qs": "^6.11.2",
    "trim-newlines": "^5.0.0",
    "xmldom": "npm:@xmldom/xmldom@^0.8.12",
    "meow": {
      "trim-newlines": "^5.0.0"
    },
    "axios": "^1.15.0",
    "lodash": "^4.17.23",
    "brace-expansion": "^1.1.14",
    "path-to-regexp": "^8.3.1",
    "picomatch": "^4.0.4",
    "undici": "^6.24.1",
    "tar": "^7.5.13",
    "file-type": "^21.3.4",
    "request": "npm:postman-request@2.88.1-postman.48"
  },
  "is-music-bot": true
}
